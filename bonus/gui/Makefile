	$(COPY_FILE) --parents MainWindow.hpp NetworkScene.hpp SimulationWorker.hpp SimDashboard.hpp $(DISTDIR)/
	$(COPY_FILE) --parents ../../src/Node/Node.cpp ../../src/RailNetwork/RailNetwork.cpp ../../src/Train/Train.cpp ../../src/Event/Event.cpp ../../src/TrainFactory/TrainFactory.cpp ../../src/DijkstraPathfinding/DijkstraPathfinding.cpp ../../src/InputHandler/InputHandler.cpp ../../src/OutputManager/OutputManager.cpp ../../src/Simulation/Simulation.cpp ../../src/FileOutputObserver/FileOutputObserver.cpp ../../src/GraphExporter/GraphExporter.cpp ../../src/TerminalAnimDisplay/TerminalAnimDisplay.cpp main.cpp MainWindow.cpp NetworkScene.cpp SimulationWorker.cpp SimDashboard.cpp $(DISTDIR)/


