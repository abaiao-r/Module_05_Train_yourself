../../bin/TrainGUI.app/Contents/PkgInfo: 
	@test -d ../../bin/TrainGUI.app/Contents || mkdir -p ../../bin/TrainGUI.app/Contents
	@$(DEL_FILE) ../../bin/TrainGUI.app/Contents/PkgInfo
	@echo "APPL????" > ../../bin/TrainGUI.app/Contents/PkgInfo
../../bin/TrainGUI.app/Contents/Info.plist: 
	@test -d ../../bin/TrainGUI.app/Contents || mkdir -p ../../bin/TrainGUI.app/Contents
	@$(DEL_FILE) ../../bin/TrainGUI.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - /opt/homebrew/share/qt/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.TrainGUI,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.TrainGUI,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},14.0,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,TrainGUI,g" -e "s,@LIBRARY@,TrainGUI,g" -e "s,\$${EXECUTABLE_NAME},TrainGUI,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >../../bin/TrainGUI.app/Contents/Info.plist

