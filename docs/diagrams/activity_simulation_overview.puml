@startuml activity_simulation_overview

skinparam defaultFontSize 11
skinparam shadowing false
skinparam ActivityFontSize 12

title Simulation — High-Level Flow (Mandatory + Bonus)

|#LightBlue|Loading|
start
:Read network file;
note right
  Nodes, Rails (bidirectional),
  Events with probabilities
end note

:Read train file;
note right
  9 fields per train:
  name weight friction accel brake
  from to time stopDuration
end note

:Validate via TrainFactory;

if (--graph flag?) then (yes)
  #LightYellow:GraphExporter::exportDot();
  note right
    **Bonus — Graph Export**
    Output: network_graph.dot
    Renders .png/.svg if dot installed
    Colour-coded train paths (8 palette)
  end note
  stop
endif

|#LightGreen|Initialisation|
:Compute shortest paths (Dijkstra);
note right
  Cost metric = distance (km)
  or time (--time-weight flag)
  One path per train
end note

:Create FileOutputObserver per train;
note right
  Opens TrainName_HHhMM.result
  Writes header + estimated time
end note

:Create TrainState per train;
note right
  segmentIndex = 0
  posOnSegment = 0
  speed = 0, stopTimer = 0
end note

if (--animate flag?) then (yes)
  #LightYellow:Register TerminalAnimDisplay;
  note right
    **Bonus — Animation**
    Callback renders terminal UI
    at 50ms frame intervals
  end note
endif

|#LightYellow|Concurrent Physics Loop|

#LightCyan:Multi-run wrapper (--runs N);
note right
  **Bonus — Multi-Run**
  Default N=1. Loop N times,
  deep-copy trains each run,
  aggregate min/avg/max times.
end note

repeat
  :simTime += 1 second;

  partition "For each active train" {
    if (not yet departed?) then (yes)
      if (simTime >= departureTime?) then (yes)
        :Mark departed;
        :Print departure to console;
      else (no)
        :Skip this train;
      endif
    elseif (station stop active?) then (yes)
      :Decrement stop timer;
      :action = "Stopped";
    else (physics step)
      :Compute forces & update speed/position;
      note right
        a_accel = (F×1000 − μ×m×1000×g) / (m×1000)
        a_decel = (F×1000 + μ×m×1000×g) / (m×1000)
      end note

      if (segment complete?) then (yes)
        :Advance to next node;
        :Check events → apply delay if triggered;
        if (final destination?) then (yes)
          :Mark arrived;
        else (no)
          :Start stop timer;
        endif
      endif
    endif

    if (every 60s interval?) then (yes)
      :Observer writes timestep line;
      note right
        [time] - [from][to] - [dist] - [action]
        Rail graph: [x] [O] [ ]
      end note
    endif
  }

  :Apply overtaking constraints;
  note right
    Same segment → behind train
    speed ≤ ahead train speed
  end note

  #LightYellow:Invoke animation callback;
  note right
    --animate: TerminalAnimDisplay::render()
    GUI: signal tick(simTime, snapshots)
    Includes usleep(FRAME_DELAY_US)
  end note

  #LightCyan:Check stop flag (GUI);
  note right
    if _stopRequested → throw
    SimulationStopException
  end note

repeat while (any train still active?) is (yes)
->no;

|#LightPink|Finalisation|
:Close all .result files;
note right
  Observer writes:
  "Actual travel time : XXhYYm"
end note

:Print console summary;
note right
  Per train: status, arrival time, delay
end note

if (--runs N > 1?) then (yes)
  #LightCyan:Print statistical summary;
  note right
    **Bonus — Multi-Run Stats**
    Per train: min / avg / max travel time
    Across N simulation runs
  end note
endif

if (--animate?) then (yes)
  #LightYellow:TerminalAnimDisplay::cleanup();
  note right
    Restore terminal state,
    show cursor
  end note
endif

stop

@enduml
