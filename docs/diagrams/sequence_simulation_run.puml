@startuml sequence_simulation_run

skinparam defaultFontSize 11
skinparam shadowing false
skinparam sequenceMessageAlign center

title Simulation Run — Full Lifecycle (Mandatory + Bonus)

actor User
participant "main / MainWindow" as Main
participant "InputHandler" as IH
participant "TrainFactory" as TF
participant "Simulation" as Sim
participant "DijkstraPathfinding" as Dijk
participant "OutputManager" as OM
participant "FileOutputObserver" as FObs
participant "RailNetwork" as Net
participant "Train" as T
participant "Event" as Ev
participant "TerminalAnimDisplay" as Anim #LightYellow
participant "GraphExporter" as GE #LightYellow
participant "SimulationWorker" as SW #LightCyan

== 1. Loading Phase ==
User -> Main : ./Train network.txt trains.txt [flags]
Main -> IH : loadData(networkFile, trainFile)

group Parse Network File
    IH -> Net : addNode("CityA"), addNode("CityB")
    IH -> Net : addConnection("CityA", "CityB", 15.0, 250.0)
    IH -> Ev ** : Event("Riot", 0.05, 172800, "CityA")
end

group Parse Train File (9 fields)
    IH -> TF : createTrain("TrainAB", 80, 0.05, 356.0, 30.0, "CityA", "CityB", 51000, 600)
    TF -> TF : validate weight > 0, friction >= 0, forces > 0, stop >= 0
    TF -> T ** : make_unique<Train>(...)
    TF --> IH : unique_ptr<Train>
end

IH --> Main : SimulationData { network, trains, events }

== 1b. Graph Export (--graph flag) ==
alt --graph flag set
    Main -> GE : exportDot("network_graph.dot", network, trains)
    note right of GE #LightYellow
        **Bonus — Graph Export**
        Writes DOT with 8-colour
        palette for train paths.
        Auto-renders PNG/SVG
        if `dot` is available.
    end note
    GE --> Main : files written
    Main --> User : "Graph exported"
    note over Main : exit (no simulation)
end

== 2. Initialisation ==
Main -> Sim ** : Simulation(network, trains, events, DijkstraPathfinding, weightMode)

alt --animate flag set
    Main -> Sim : setAnimCallback(anim.render)
    note right of Sim #LightYellow
        **Bonus — Animation**
        Registers TerminalAnimDisplay
        callback invoked each frame.
    end note
end

alt GUI mode
    Main -> SW ** : SimulationWorker()
    Main -> SW : moveToThread(workerThread)
    note right of SW #LightCyan
        **Bonus — GUI**
        Simulation runs in QThread.
        Signals: tick(), finished(), error()
    end note
end

== 3. Simulation Run ==
alt CLI
    Main -> Sim : run()
else GUI
    Main -> SW : runSimulation(netFile, trainFile, useTimeWeight)
    SW -> Sim : run()
end

group Path Computation
    Sim -> OM : printNetwork(network)
    loop for each train
        Sim -> Dijk : findPath(departureStation, arrivalStation, network, mode)
        Dijk -> Net : getNeighbours(node)
        Dijk --> Sim : vector<Node> path
        Sim -> T : setPath(path)
        Sim -> OM : printTrainPath(train)
    end
end

group Create Observers & States
    loop for each train
        Sim -> FObs ** : FileOutputObserver(trainName, departureTime)
        Sim -> Sim : TrainState { train*, segIdx=0, pos=0, speed=0, stopTimer=0 }
        Sim -> Sim : estimateTravelTime(train) → analytical estimate
        Sim -> FObs : onTrainStart(trainName, trainId, estimatedTime)
    end
end

group Concurrent Physics Loop (DT = 1s)
    loop simTime += 1s while any train active
        loop for each train
            alt not yet departed
                alt simTime >= departureTime
                    Sim -> T : setStatus(Running)
                    Sim -> OM : printDeparture(train)
                end
            else station stop timer > 0
                Sim -> Sim : stopTimer -= DT
                note right
                    Train stays at position 0,
                    speed 0, action = "Stopped"
                end note
            else normal physics
                Sim -> Sim : updatePhysics(state)
                note right
                    1. Compute braking distance = v² / (2·decelRate)
                    2. If distToEnd <= brakingDist → brake
                    3. Else if speed < speedLimit → accelerate
                    4. Else → maintain speed
                    5. Clamp to speedLimit
                    6. pos += speed · DT
                end note
                alt segment complete (pos >= segmentLength)
                    Sim -> Sim : handleSegmentTransition(state, idx)
                    Sim -> T : advanceToNextNode(...)
                    Sim -> OM : printArrival(train, node, time)
                    group Node Event Check
                        Sim -> Sim : getEventsAtNode(nodeName)
                        Sim -> Ev : tryTrigger(rng)
                        alt event triggers
                            Sim -> T : applyDelay(duration)
                            Sim -> OM : printEvent(event, train)
                            Sim -> FObs : onTrainEvent(eventName, nodeName, delay)
                        end
                    end
                    group Rail Segment Event Check
                        Sim -> Sim : getEventsOnSegment(from, to)
                        Sim -> Ev : tryTrigger(rng)
                        alt event triggers
                            Sim -> T : applyDelay(duration)
                            Sim -> FObs : onTrainEvent(eventName, "from-to", delay)
                        end
                    end
                    alt not final destination
                        Sim -> Sim : stopTimer = train.stopDuration
                    else final destination
                        Sim -> Sim : state.arrived = true
                    end
                end
            end

            alt every 60 seconds
                Sim -> FObs : onTrainStep(time, from, to, distRem, action, posKm, segKm, blocking)
                note right of FObs
                    Writes line: [time] - [from][to] - [dist] - [action] - rail graph
                    Rail graph: [x]=position, [O]=blocking, [ ]=empty
                end note
            end
        end

        Sim -> Sim : applyBlocking(states)
        note right
            Trains on same segment:
            behind train speed ≤ ahead train speed
        end note

        alt animation callback registered
            Sim -> Anim : render(simTime, states)
            note right of Anim #LightYellow
                Terminal: ANSI progress bars
                GUI: signal tick(simTime, snapshots)
                usleep(FRAME_DELAY_US / speedMult)
            end note
        end

        alt GUI — stop requested
            Sim -> Sim : check _stopRequested.load()
            note right #LightCyan
                throws SimulationStopException
                caught by SimulationWorker
            end note
        end
    end
end

group Finalize
    loop for each train
        Sim -> FObs : onTrainFinish(trainName, totalTimeSec)
        note right of FObs
            Writes: "Actual travel time : XXhYYm"
            Closes .result file
        end note
    end
    Sim -> OM : printResult(trains)
    OM --> User : Console summary (status, arrival time, delays)
end

alt --animate flag
    Sim -> Anim : cleanup()
    note right of Anim #LightYellow
        Restore terminal, show cursor
    end note
end

alt --runs N > 1
    note over Main #LightCyan
        **Bonus — Multi-Run**
        Loop repeats N times with
        deep-copied trains. After all
        runs, prints min/avg/max
        travel times per train.
    end note
end

alt GUI mode
    SW --> Main : signal finished(results)
    note right of SW #LightCyan
        MainWindow updates dashboard
        with final results table
    end note
end

@enduml
