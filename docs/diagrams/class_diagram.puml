@startuml class_diagram

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam defaultFontSize 10
skinparam shadowing false
skinparam packageStyle rectangle
skinparam dpi 150

left to right direction

title Train Simulator — Complete Class Diagram (Mandatory + Bonus)

package "Domain" {
    class Node {
        - _name : string
        + Node(name : string)
        + Node(src : Node)
        + operator=(src : Node) : Node&
        + ~Node()
        + getName() : string
    }

    class "Node::InvalidNameException" as NodeEx {
    }
    NodeEx --|> std::invalid_argument

    struct Edge <<struct>> {
        + destination : shared_ptr<Node>
        + distance : double
        + speedLimit : double
    }
    Edge --> Node : destination

    class RailNetwork {
        - _nodes : unordered_map<string, shared_ptr<Node>>
        - _adjacencyList : unordered_map<string, vector<Edge>>
        + RailNetwork()
        + RailNetwork(src : RailNetwork)
        + RailNetwork(src : RailNetwork&&)
        + operator=(src : RailNetwork) : RailNetwork&
        + operator=(src : RailNetwork&&) : RailNetwork&
        + ~RailNetwork()
        + addNode(name : string) : void
        + addConnection(from, to, distance, speedLimit) : void
        + findNode(name : string) : shared_ptr<Node>
        + getNeighbours(nodeName : string) : vector<Edge>
        + getNodeNames() : vector<string>
        + nodeCount() : size_t
    }
    RailNetwork *-- Node : contains
    RailNetwork *-- Edge : adjacency list

    enum TrainStatus {
        Waiting
        Running
        Arrived
        Delayed
    }

    class Train {
        - _id : int
        - _name : string
        - _weight : double              «metric tons»
        - _frictionCoefficient : double
        - _maxAccelForce : double       «kilonewtons»
        - _maxBrakeForce : double       «kilonewtons»
        - _departureStation : string
        - _arrivalStation : string
        - _departureTime : double       «seconds from midnight»
        - _stopDuration : double        «seconds at each station»
        - _status : TrainStatus
        - _path : vector<shared_ptr<Node>>
        - _pathIndex : size_t
        - _currentTime : double
        - _totalDelay : double
        - _currentSpeed : double        «m/s»
        - _posOnSegment : double        «metres»
        + Train(id, name, weight, friction, accelForce, brakeForce, departure, arrival, departureTime, stopDuration)
        + Train(src : Train)
        + operator=(src : Train) : Train&
        + ~Train()
        + getId() : int
        + setPath(path) : void
        + advanceToNextNode(travelTime : double) : void
        + applyDelay(seconds : double) : void
        + setStatus(status) : void
        + setCurrentSpeed(speed : double) : void
        + setPosOnSegment(pos : double) : void
        + setPathIndex(idx : size_t) : void
        + setCurrentTime(t : double) : void
        + getAccelRate() : double
        + getDecelRate() : double
        + hasArrived() : bool
        + {static} statusToString(status : TrainStatus) : string
    }
    Train --> Node : path
    Train --> TrainStatus

    class Event {
        - _name : string
        - _probability : double
        - _duration : double
        - _nodeName : string
        - _nodeName2 : string
        + Event(name, probability, duration, nodeName, nodeName2 = "")
        + tryTrigger(rng : mt19937&) : bool
        + getName() : string
        + getProbability() : double
        + getDuration() : double
        + getNodeName() : string
        + getNodeName2() : string
        + isRailEvent() : bool
    }
}

package "Strategy" {
    enum PathWeightMode {
        Distance
        Time
    }

    interface IPathfinding <<interface>> {
        + {abstract} findPath(start, end, network, mode : PathWeightMode) : vector<shared_ptr<Node>>
    }

    class DijkstraPathfinding {
        + findPath(start, end, network, mode : PathWeightMode) : vector<shared_ptr<Node>>
        # {static} edgeWeight(edge : Edge, mode : PathWeightMode) : double
    }
    DijkstraPathfinding ..|> IPathfinding : implements
    DijkstraPathfinding ..> RailNetwork : reads graph
    IPathfinding ..> PathWeightMode : uses
}

package "Factory" {
    class TrainFactory {
        - TrainFactory() = delete
        - {static} _nextId : int
        + {static} createTrain(name, weight, friction, accelForce, brakeForce, dep, arr, time, stop) : unique_ptr<Train>
        + {static} resetIdCounter() : void
    }
    TrainFactory ..> Train : creates
}

package "Observer" {
    interface ISimulationObserver <<interface>> {
        + {abstract} onTrainStart(trainName, trainId, estimatedTimeSec) : void
        + {abstract} onTrainStep(timeSinceStart, from, to, distRemKm, action, posKm, segKm, blocking) : void
        + {abstract} onTrainEvent(eventName, nodeName, delaySec) : void
        + {abstract} onTrainFinish(trainName, totalTimeSec) : void
    }

    class FileOutputObserver {
        - _file : ofstream
        - _filename : string
        - {static} buildFilename(trainName, departureTime) : string
        - {static} fmtTimeShort(seconds) : string
        - {static} padRight(s, width) : string
        + FileOutputObserver(trainName, departureTime)
        + ~FileOutputObserver()
        + onTrainStart(...) : void
        + onTrainStep(...) : void
        + onTrainEvent(...) : void
        + onTrainFinish(...) : void
    }
    FileOutputObserver ..|> ISimulationObserver : implements
}

package "I/O" {
    struct SimulationData <<struct>> {
        + network : RailNetwork
        + trains : vector<unique_ptr<Train>>
        + events : vector<Event>
    }

    class InputHandler {
        - InputHandler() = delete
        + {static} loadData(networkFile, trainFile) : SimulationData
        + {static} parseNetworkFile(file, net, events) : void
        + {static} parseTrainFile(file) : vector<unique_ptr<Train>>
    }
    InputHandler ..> SimulationData : produces
    InputHandler ..> RailNetwork : builds
    InputHandler ..> TrainFactory : uses
    InputHandler ..> Event : creates

    class OutputManager {
        + printNetwork(net : RailNetwork) : void
        + printTrainPath(train : Train) : void
        + printDeparture(train : Train) : void
        + printArrival(train : Train, node, time) : void
        + printEvent(event : Event, train : Train) : void
        + printResult(trains) : void
        + {static} formatTime(seconds : double) : string
    }

    class GraphExporter {
        - GraphExporter() = delete
        + {static} exportDot(filename, network, trains) : void
    }
    GraphExporter ..> RailNetwork : reads
    GraphExporter ..> Train : reads paths
}

package "Orchestration" {
    struct TrainState <<struct>> {
        + train : Train*
        + segmentIndex : size_t
        + posOnSegment_m : double
        + speed_ms : double
        + timeSinceDepart : double
        + stopTimer : double
        + departed : bool
        + arrived : bool
    }

    class Simulation {
        - _network : RailNetwork
        - _trains : vector<unique_ptr<Train>>
        - _events : vector<Event>
        - _pathfinder : unique_ptr<IPathfinding>
        - _weightMode : PathWeightMode
        - _output : OutputManager
        - _observers : vector<unique_ptr<ISimulationObserver>>
        - _animCallback : function<void(double, vector<TrainState>)>
        - _rng : mt19937
        - _quiet : bool
        - {static} DT : double = 1.0
        - {static} OUTPUT_INTERVAL : double = 60.0
        + Simulation(network, trains, events, pathfinder, weightMode)
        + ~Simulation()
        + run() : void
        + setAnimCallback(cb) : void
        + setQuiet(q : bool) : void
        + getResults() : map<string, pair<double, double>>
        - computePaths() : void
        - estimateTravelTime(train) : double
        - updatePhysics(s : TrainState&) : void
        - handleSegmentTransition(s : TrainState&, idx) : void
        - applyBlocking(states : vector<TrainState>&) : void
        - getEventsAtNode(nodeName) : vector<Event*>
        - getEventsOnSegment(from, to) : vector<Event*>
    }
    Simulation *-- RailNetwork : owns
    Simulation *-- Train : owns
    Simulation *-- Event : owns
    Simulation *-- OutputManager : owns
    Simulation *-- TrainState : runtime state
    Simulation --> IPathfinding : uses (injected)
    Simulation *-- ISimulationObserver : notifies
}

package "Bonus — Terminal Animation" #LightYellow {
    class TerminalAnimDisplay {
        - _firstFrame : bool
        - _lastLineCount : int
        + render(simTime : double, states : vector<TrainState>) : void
        + cleanup() : void
        - {static} fmtTime(seconds) : string
        - {static} progressBar(fraction, width) : string
        - {static} speedStr(speed_ms) : string
        - {static} visLen(s : string) : size_t
        - {static} boxLine(content : string) : string
    }
    TerminalAnimDisplay ..> TrainState : renders
    Simulation ..> TerminalAnimDisplay : animCallback
}

package "Bonus — Qt GUI" #LightCyan {
    class MainWindow <<QMainWindow>> {
        - _network : RailNetwork
        - _trainDefs : vector<unique_ptr<Train>>
        - _eventDefs : vector<Event>
        - _simRunning : bool
        + onRunSimulation() : void
        + onStopSimulation() : void
        + onFitGraph() : void
        + onSpeedChanged(value : int) : void
        - buildMenus() : void
        - buildToolbar() : void
        - buildCentralWidget() : void
        - buildSidebar() : void
    }

    class NetworkScene <<QGraphicsScene>> {
        - _nodes : map<string, NodeVis>
        - _edges : vector<EdgeVis>
        + loadFromNetwork(net : RailNetwork) : void
        + addNode(name, pos) : void
        + removeNode(name) : void
        + addEdge(from, to, dist, speed) : void
        + updateTrains(simTime, snapshots) : void
        + clearTrains() : void
        + layoutForceDirected() : void
    }

    class SimulationWorker <<QObject>> {
        - _speedMult : atomic<double>
        - _stopRequested : atomic<bool>
        + runSimulation(netFile, trainFile, useTimeWeight) : void
        + setSpeedMultiplier(mult : double) : void
        + requestStop() : void
        ..signals..
        + tick(simTime, snapshots) : void
        + finished(results) : void
        + error(msg) : void
    }

    struct TrainSnapshot <<struct>> {
        + name : string
        + from, to : string
        + posOnSegment_m : double
        + speed_ms : double
        + departed, arrived : bool
    }

    class SimDashboard <<QTextEdit>> {
        + update(simTime, snapshots) : void
        + showResults(results) : void
        + clear() : void
        - {static} visLen(html) : int
        - {static} visTruncate(html, max) : string
        - {static} boxRow(content) : string
    }

    MainWindow *-- NetworkScene
    MainWindow *-- SimDashboard
    MainWindow --> SimulationWorker : controls
    SimulationWorker ..> TrainSnapshot : emits
    SimulationWorker ..> Simulation : runs internally
    NetworkScene ..> TrainSnapshot : renders
    SimDashboard ..> TrainSnapshot : renders
}

@enduml
