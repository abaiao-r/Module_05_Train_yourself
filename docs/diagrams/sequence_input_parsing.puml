@startuml sequence_input_parsing

skinparam defaultFontSize 11
skinparam shadowing false
skinparam sequenceMessageAlign center

title Input Parsing — File Loading Sequence

participant "main" as Main
participant "InputHandler" as IH
participant "RailNetwork" as Net
participant "TrainFactory" as TF
participant "Train" as T
participant "Event" as Ev

Main -> IH : loadData("network.txt", "trains.txt")

== Network File Parsing ==
IH -> IH : parseNetworkFile(filepath, network, events)

group Read lines from network.txt
    IH -> IH : read line "Node CityA"
    IH -> Net : addNode("CityA")

    IH -> IH : read line "Node CityB"
    IH -> Net : addNode("CityB")

    IH -> IH : read line "Rail CityA CityB 15.0 250.0"
    IH -> Net : addConnection("CityA", "CityB", 15.0, 250.0)
    note right of Net
        Bidirectional: adds edge
        CityA→CityB and CityB→CityA
    end note

    IH -> IH : read line: Event "Passenger's Discomfort" 0.2 30m CityA
    IH -> IH : parseQuotedOrWord() → "Passenger's Discomfort"
    IH -> IH : parseDuration("30m") → 1800.0 seconds
    IH -> Ev ** : Event("Passenger's Discomfort", 0.2, 1800.0, "CityA")

    IH -> IH : read line: Event "Track Maintenance" 0.1 45m CityA CityB
    IH -> IH : parseQuotedOrWord() → "Track Maintenance"
    IH -> IH : parseDuration("45m") → 2700.0 seconds
    IH -> IH : read optional nodeName2 → "CityB" (rail segment event)
    IH -> Ev ** : Event("Track Maintenance", 0.1, 2700.0, "CityA", "CityB")
end

== Train File Parsing (9-field format) ==
IH -> IH : parseTrainFile(filepath)

group Read lines from trains.txt
    IH -> IH : read line "TrainAB 80 0.05 356.0 30.0 CityA CityB 14h10 00h10"
    IH -> IH : parse: name=TrainAB, weight=80, friction=0.05
    IH -> IH : parse: accelForce=356.0, brakeForce=30.0
    IH -> IH : parse: departure=CityA, arrival=CityB
    IH -> IH : parseTime("14h10") → 51000.0 seconds
    IH -> IH : parseTime("00h10") → 600.0 seconds (stop duration)
    IH -> TF : createTrain("TrainAB", 80, 0.05, 356.0, 30.0, "CityA", "CityB", 51000.0, 600.0)

    group TrainFactory Validation
        TF -> TF : name not empty? ✓
        TF -> TF : weight > 0? ✓
        TF -> TF : friction >= 0? ✓
        TF -> TF : accelForce > 0? ✓
        TF -> TF : brakeForce > 0? ✓
        TF -> TF : departure ≠ arrival? ✓
        TF -> TF : departureTime ≥ 0? ✓
        TF -> TF : stopDuration ≥ 0? ✓
    end

    TF -> T ** : make_unique<Train>(nextId++, name, weight, friction, accelForce, brakeForce, dep, arr, time, stop)
    TF --> IH : unique_ptr<Train>
end

IH --> Main : SimulationData { network, trains, events }

@enduml
